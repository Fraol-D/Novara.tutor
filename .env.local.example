# Environment Variables for NovaraTutor

# Frontend API base URL for dashboard/auth requests
# Local default backend: http://localhost:4000/api
VITE_API_BASE_URL=http://localhost:4000/api

# Resend API Key (get yours at https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email address to receive contact form submissions
CONTACT_EMAIL=contact@novaratutor.com
