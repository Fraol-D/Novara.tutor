generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PARENT
  TUTOR
  ADMIN
}

enum TutorApplicationStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum ProficiencyLevel {
  NATIVE
  FLUENT
  COMFORTABLE
}

enum EducationType {
  HIGH_SCHOOL
  COLLEGE
  OTHER_CERTIFICATION
}

enum ExperienceType {
  TEACHING
  WORK
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum PackagePlan {
  GROW
  THRIVE
  EXCEL
}

enum ReportType {
  MASTERY
  PREREQUISITE
}

model User {
  id                String            @id @default(uuid())
  email             String            @unique
  passwordHash      String
  firstName         String
  lastName          String
  role              UserRole?
  country           String?
  state             String?
  phone             String?
  profilePictureUrl String?
  setupStep         Int               @default(1)
  setupCompleted    Boolean           @default(false)
  tutorApplication  TutorApplication?
  children          ParentChild[]     @relation("ParentChildren")
  assessmentReports AssessmentReport[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model ParentChild {
  id                String            @id @default(uuid())
  parentId          String
  parent            User              @relation("ParentChildren", fields: [parentId], references: [id])
  firstName         String
  lastName          String
  dateOfBirth       DateTime?
  grade             String?
  country           String?
  state             String?
  schoolInUsa       Boolean?
  packagePlan       PackagePlan?
  profilePictureUrl String?
  notes             String?
  timeSlots         ChildTimeSlot[]
  syllabusEntries   AcademicSyllabus[]
  roadmapEntries    AcademicRoadmap[]
  reports           AssessmentReport[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([parentId])
}

model ChildTimeSlot {
  id        String   @id @default(uuid())
  childId   String
  child     ParentChild @relation(fields: [childId], references: [id])
  day       Weekday
  startTime String
  endTime   String
  timezone  String   @default("Local")
  createdAt DateTime @default(now())

  @@index([childId])
}

model TutorApplication {
  id                 String                 @id @default(uuid())
  userId             String                 @unique
  user               User                   @relation(fields: [userId], references: [id])
  status             TutorApplicationStatus @default(DRAFT)
  currentStep        Int                    @default(1)
  submittedAt        DateTime?
  languageSkills     LanguageSkill[]
  educationEntries   EducationEntry[]
  experienceEntries  ExperienceEntry[]
  availabilitySlots  TutorAvailability[]
  languageDemoVideos LanguageDemoVideo[]
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
}

model LanguageSkill {
  id            String           @id @default(uuid())
  applicationId String
  application   TutorApplication @relation(fields: [applicationId], references: [id])
  language      String
  proficiency   ProficiencyLevel
  demoVideo     LanguageDemoVideo?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([applicationId, language])
  @@index([applicationId])
}

model EducationEntry {
  id              String           @id @default(uuid())
  applicationId   String
  application     TutorApplication @relation(fields: [applicationId], references: [id])
  type            EducationType
  institutionName String
  studyArea       String?
  startDate       DateTime?
  endDate         DateTime?
  completedYear   Int?
  graduated       Boolean          @default(false)
  transcriptUrl   String?
  certificateUrl  String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([applicationId])
}

model ExperienceEntry {
  id               String           @id @default(uuid())
  applicationId    String
  application      TutorApplication @relation(fields: [applicationId], references: [id])
  type             ExperienceType
  organizationName String
  title            String
  description      String?
  startDate        DateTime?
  endDate          DateTime?
  currentlyWorking Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([applicationId])
}

model TutorAvailability {
  id            String           @id @default(uuid())
  applicationId String
  application   TutorApplication @relation(fields: [applicationId], references: [id])
  day           Weekday
  startTime     String
  endTime       String
  timezone      String           @default("Local")
  totalHours    Decimal?         @db.Decimal(4, 2)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([applicationId])
}

model LanguageDemoVideo {
  id              String           @id @default(uuid())
  applicationId   String
  application     TutorApplication @relation(fields: [applicationId], references: [id])
  languageSkillId String           @unique
  languageSkill   LanguageSkill    @relation(fields: [languageSkillId], references: [id])
  url             String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([applicationId])
}

model AcademicSyllabus {
  id        String      @id @default(uuid())
  childId   String
  child     ParentChild @relation(fields: [childId], references: [id])
  subject   String
  country   String?
  state     String?
  grade     String?
  content   Json
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([childId])
}

model AcademicRoadmap {
  id        String      @id @default(uuid())
  childId   String
  child     ParentChild @relation(fields: [childId], references: [id])
  subject   String
  country   String?
  state     String?
  grade     String?
  content   Json
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([childId])
}

model AssessmentReport {
  id          String      @id @default(uuid())
  parentId    String
  parent      User        @relation(fields: [parentId], references: [id])
  childId     String
  child       ParentChild @relation(fields: [childId], references: [id])
  type        ReportType
  subject     String
  title       String
  summary     String
  score       Int?
  publishedAt DateTime    @default(now())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([parentId])
  @@index([childId])
}
